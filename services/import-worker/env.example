# Database
IMPORT_WORKER_CONNECTION_STRING=postgresql://user:password@localhost:5432/agora
# IMPORT_WORKER_CONNECTION_STRING_READ=postgresql://user:password@localhost:5433/agora

# Valkey
IMPORT_WORKER_VALKEY_URL=valkey://localhost:6379

# Worker settings
IMPORT_WORKER_FLUSH_INTERVAL_MS=1000
IMPORT_WORKER_MAX_BATCH_SIZE=4
IMPORT_WORKER_MAX_CONCURRENCY=2
IMPORT_WORKER_STALE_THRESHOLD_MS=300000
IMPORT_WORKER_STALE_CLEANUP_EVERY_N_FLUSHES=60
