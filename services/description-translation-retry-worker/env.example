# Database
DESCRIPTION_TRANSLATION_RETRY_WORKER_CONNECTION_STRING=postgresql://user:password@localhost:5432/agora
# DESCRIPTION_TRANSLATION_RETRY_WORKER_CONNECTION_STRING_READ=postgresql://user:password@localhost:5433/agora

# Valkey
DESCRIPTION_TRANSLATION_RETRY_WORKER_VALKEY_URL=valkey://localhost:6379

# Retry worker settings
# Defaults to DEBUG when AGORA_DEV_MODE=true, otherwise INFO.
# DESCRIPTION_TRANSLATION_RETRY_WORKER_LOG_LEVEL=INFO
DESCRIPTION_TRANSLATION_RETRY_WORKER_VALKEY_POP_BATCH_SIZE=50
DESCRIPTION_TRANSLATION_RETRY_WORKER_DB_CLAIM_BATCH_SIZE=8
DESCRIPTION_TRANSLATION_RETRY_WORKER_MAX_AI_DESCRIPTION_CONCURRENCY=4
DESCRIPTION_TRANSLATION_RETRY_WORKER_LEASE_TTL_SECONDS=45
DESCRIPTION_TRANSLATION_RETRY_WORKER_HEARTBEAT_INTERVAL_SECONDS=15
DESCRIPTION_TRANSLATION_RETRY_WORKER_WORKER_POLL_IDLE_SLEEP_SECONDS=0.5
DESCRIPTION_TRANSLATION_RETRY_WORKER_RECONCILIATION_INTERVAL_SECONDS=60
DESCRIPTION_TRANSLATION_RETRY_WORKER_RUNNING_RECOVERY_INTERVAL_SECONDS=10
DESCRIPTION_TRANSLATION_RETRY_WORKER_VALKEY_RETRY_INTERVAL_SECONDS=5.0

# Translation providers. Enable Bedrock and configure Google credentials for
# Bedrock-first, Google-fallback translation.
# DESCRIPTION_TRANSLATION_RETRY_WORKER_GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
DESCRIPTION_TRANSLATION_RETRY_WORKER_AWS_DESCRIPTION_TRANSLATION_ENABLE=true
DESCRIPTION_TRANSLATION_RETRY_WORKER_AWS_DESCRIPTION_TRANSLATION_READ_TIMEOUT_SECONDS=12.0
DESCRIPTION_TRANSLATION_RETRY_WORKER_GOOGLE_CLOUD_TRANSLATION_TIMEOUT_SECONDS=10.0

# Dev-only retry simulation. Requires AGORA_DEV_MODE=true.
DESCRIPTION_TRANSLATION_RETRY_WORKER_SIMULATION_PROVIDERS_ENABLE=false
DESCRIPTION_TRANSLATION_RETRY_WORKER_AI_DESCRIPTION_SIMULATION_MODE=off
DESCRIPTION_TRANSLATION_RETRY_WORKER_DESCRIPTION_TRANSLATION_SIMULATION_MODE=off
DESCRIPTION_TRANSLATION_RETRY_WORKER_SIMULATION_RETRYABLE_FAILURE_ATTEMPTS=1
