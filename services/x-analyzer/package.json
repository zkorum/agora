{
    "name": "@zkorum/agora-x-analyzer",
    "version": "1.0.0",
    "description": "Fetch X thread data and generate Polis CSV files for Agora import",
    "type": "module",
    "scripts": {
        "x-fetch": "tsx src/fetch.ts",
        "to-csv": "tsx src/to-csv.ts",
        "test": "vitest run",
        "lint": "eslint .",
        "format:write": "prettier --write \"**/*.{js,ts,jsx,tsx,json}\"",
        "format:check": "prettier . --check"
    },
    "author": "ZKorum SAS <hello@zkorum.com>",
    "license": "AGPL-3.0",
    "dependencies": {
        "dotenv": "^17.3.1",
        "openai": "^6.25.0",
        "twitter-api-v2": "^1.29.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.3",
        "@types/eslint__js": "^8.42.3",
        "@types/node": "^25.3.0",
        "eslint": "^9.27.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.3.0",
        "msw": "^2.9.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.56.0",
        "vitest": "^4.0.0"
    },
    "pnpm": {
        "overrides": {
            "vite": ">=7.3.2",
            "picomatch": ">=4.0.4",
            "flatted": ">=3.4.2"
        }
    }
