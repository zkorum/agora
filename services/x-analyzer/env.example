# X API v2 Bearer Token (from https://developer.x.com/en/portal/dashboard)
X_BEARER_TOKEN=your_bearer_token_here

# xAI API Key (from https://console.x.ai/) — optional
# When set, enables Grok-powered scout, bot detection, and enrichment phases.
# When unset, x-fetch behaves exactly as before (pure Twitter API v2).
XAI_API_KEY=your_xai_api_key_here
