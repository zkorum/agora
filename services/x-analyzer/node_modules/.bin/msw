#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.pnpm/msw@2.12.10_@types+node@25.3.3_typescript@5.9.3/node_modules/msw/cli/index.js" "$@"
else
  exec node  "$basedir/../.pnpm/msw@2.12.10_@types+node@25.3.3_typescript@5.9.3/node_modules/msw/cli/index.js" "$@"
fi
