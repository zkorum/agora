#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.pnpm/openai@6.25.0_zod@4.3.6/node_modules/openai/bin/cli" "$@"
else
  exec node  "$basedir/../.pnpm/openai@6.25.0_zod@4.3.6/node_modules/openai/bin/cli" "$@"
fi
