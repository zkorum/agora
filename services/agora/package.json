{
  "name": "@zkorum/agora-app",
  "version": "0.0.8",
  "description": "Where citizens converge to exchange and debate ideas.",
  "productName": "Agora Citizen Network",
  "author": "ZKorum SAS <hello@zkorum.com>",
  "license": "MPL-2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "lint:fix": "pnpm lint --fix",
    "format:write": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\"",
    "format:check": "prettier . --check",
    "prepare": "quasar prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "quasar dev",
    "start": "serve dist/spa",
    "build:dev": "env-cmd -f .env.dev.build quasar build",
    "build:staging": "env-cmd -f .env.staging quasar build",
    "build:production": "env-cmd -f .env.production quasar build",
    "image:build": "docker build -f Dockerfile.production -t agora-app .",
    "image:buildx": "docker buildx build -f Dockerfile.production --platform linux/amd64 -t agora-app --load .",
    "image:build:staging": "docker build -f Dockerfile.staging -t agora-app-staging .",
    "image:buildx:staging": "docker buildx build -f Dockerfile.staging --platform linux/amd64 -t agora-app-staging --load .",
    "image:build:production": "docker build -f Dockerfile.production -t agora-app-production .",
    "image:buildx:production": "docker buildx build -f Dockerfile.production --platform linux/amd64 -t agora-app-production --load .",
    "image:tag": "docker tag zkorum-frontJustForExample:latest zkorum/frontJustForExample:0.1.0",
    "image:push": "docker image push zkorum/frontJustForExample:0.1.0"
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@parcnet-js/app-connector": "^1.1.10",
    "@parcnet-js/podspec": "^1.2.0",
    "@parcnet-js/ticket-spec": "^1.1.9",
    "@pcd/gpc": "^0.4.0",
    "@primeuix/themes": "^2.0.3",
    "@quasar/extras": "^1.18.0",
    "@sentry/vue": "^10.49.0",
    "@tanstack/vue-query": "^5.99.2",
    "@tiptap/core": "3.22.4",
    "@tiptap/extension-bubble-menu": "^3.22.4",
    "@tiptap/extension-placeholder": "3.22.4",
    "@tiptap/extensions": "3.22.4",
    "@tiptap/pm": "3.22.4",
    "@tiptap/starter-kit": "3.22.4",
    "@tiptap/vue-3": "3.22.4",
    "@ucans/ucans": "^0.12.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/integrations": "^14.2.1",
    "@vueuse/router": "^14.2.1",
    "@zkorum/keystore-idb": "^0.18.1",
    "axios": "^1.15.1",
    "buffer": "^6.0.3",
    "cborg": "^5.1.0",
    "html2canvas": "^1.4.1",
    "inapp-spy": "^5.0.9",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "libphonenumber-js": "^1.12.41",
    "linkify-html": "^4.3.2",
    "linkifyjs": "^4.3.2",
    "localforage": "^1.10.0",
    "maz-ui": "4.9.1",
    "multiformats": "^13.4.1",
    "pinia": "^3.0.2",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "qrcode": "^1",
    "quasar": "^2.19.3",
    "sanitize-html": "^2.17.3",
    "tweetnacl": "^1.0.3",
    "uint8arrays": "^5.1.1",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@iconify/vue": "^5.0.0",
    "@quasar/app-vite": "2.6.0",
    "@sentry/vite-plugin": "^5.2.0",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.5.0",
    "env-cmd": "^11.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "postcss-rtlcss": "^6.0.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "serve": "^14.2.6",
    "terser": "^5.46.1",
    "tidewave": "^0.6.0",
    "typescript": "5.9.3",
    "vite": "^8.0.9",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.7"
  },
  "engines": {
    "node": "^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@commander-js/extra-typings>commander": "14"
      }
    },
    "overrides": {
      "eslint>ajv": "^6.14.0",
      "@eslint/eslintrc>ajv": "^6.14.0",
      "valibot": "^1.2.0",
      "yaml": "2.8.3",
      "bn.js": "5.2.3",
      "picomatch": "4.0.4",
      "jsonpath": "1.3.0",
      "underscore": "1.13.8"
    }
  }
}
