# Database
AI_DESCRIPTION_RETRY_WORKER_CONNECTION_STRING=postgresql://user:password@localhost:5432/agora
# AI_DESCRIPTION_RETRY_WORKER_CONNECTION_STRING_READ=postgresql://user:password@localhost:5433/agora

# Valkey
AI_DESCRIPTION_RETRY_WORKER_VALKEY_URL=valkey://localhost:6379

# Retry worker settings
# Defaults to DEBUG when AGORA_DEV_MODE=true, otherwise INFO.
# AI_DESCRIPTION_RETRY_WORKER_LOG_LEVEL=INFO
AI_DESCRIPTION_RETRY_WORKER_VALKEY_POP_BATCH_SIZE=50
AI_DESCRIPTION_RETRY_WORKER_DB_CLAIM_BATCH_SIZE=8
AI_DESCRIPTION_RETRY_WORKER_MAX_AI_DESCRIPTION_CONCURRENCY=4
AI_DESCRIPTION_RETRY_WORKER_LEASE_TTL_SECONDS=45
AI_DESCRIPTION_RETRY_WORKER_HEARTBEAT_INTERVAL_SECONDS=15
AI_DESCRIPTION_RETRY_WORKER_WORKER_POLL_IDLE_SLEEP_SECONDS=0.5
AI_DESCRIPTION_RETRY_WORKER_RECONCILIATION_INTERVAL_SECONDS=60
AI_DESCRIPTION_RETRY_WORKER_RUNNING_RECOVERY_INTERVAL_SECONDS=10
AI_DESCRIPTION_RETRY_WORKER_VALKEY_RETRY_INTERVAL_SECONDS=5.0

# Real AI provider. Enabled by default and configured through normal AWS
# credentials plus region/model settings. Set false for simulations or local
# runs that must not call Bedrock.
# AI_DESCRIPTION_RETRY_WORKER_AWS_AI_LABEL_SUMMARY_ENABLE=true
AI_DESCRIPTION_RETRY_WORKER_AWS_AI_LABEL_SUMMARY_REGION=us-east-1
AI_DESCRIPTION_RETRY_WORKER_AWS_AI_LABEL_SUMMARY_MODEL_ID=mistral.mistral-large-3-675b-instruct
AI_DESCRIPTION_RETRY_WORKER_AWS_AI_LABEL_SUMMARY_READ_TIMEOUT_SECONDS=60.0

# Dev-only retry simulation. Requires AGORA_DEV_MODE=true.
AI_DESCRIPTION_RETRY_WORKER_SIMULATION_PROVIDERS_ENABLE=false
AI_DESCRIPTION_RETRY_WORKER_AI_DESCRIPTION_SIMULATION_MODE=off
AI_DESCRIPTION_RETRY_WORKER_DESCRIPTION_TRANSLATION_SIMULATION_MODE=off
AI_DESCRIPTION_RETRY_WORKER_SIMULATION_RETRYABLE_FAILURE_ATTEMPTS=1
