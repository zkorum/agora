# Database
MATH_UPDATER_CONNECTION_STRING=postgresql://user:password@localhost:5432/agora
# MATH_UPDATER_CONNECTION_STRING_READ=postgresql://user:password@localhost:5433/agora

# Valkey
MATH_UPDATER_VALKEY_URL=valkey://localhost:6379

# Worker settings
# Set by repository dev Make targets. Required for simulation providers.
AGORA_DEV_MODE=false
# Defaults to DEBUG when AGORA_DEV_MODE=true, otherwise INFO.
# MATH_UPDATER_LOG_LEVEL=INFO
MATH_UPDATER_VALKEY_POP_BATCH_SIZE=50
MATH_UPDATER_DB_CLAIM_BATCH_SIZE=8
MATH_UPDATER_DB_WRITE_BATCH_SIZE=10
MATH_UPDATER_MAX_COMPUTE_CONCURRENCY=4
MATH_UPDATER_MAX_AI_DESCRIPTION_CONCURRENCY=4
MATH_UPDATER_LEASE_TTL_SECONDS=45
MATH_UPDATER_HEARTBEAT_INTERVAL_SECONDS=15
MATH_UPDATER_WORKER_POLL_IDLE_SLEEP_SECONDS=0.5
MATH_UPDATER_DEFAULT_DEBOUNCE_SECONDS=5
MATH_UPDATER_RECONCILIATION_INTERVAL_SECONDS=60
MATH_UPDATER_RUNNING_RECOVERY_INTERVAL_SECONDS=10
MATH_UPDATER_VALKEY_RETRY_INTERVAL_SECONDS=5.0

# AWS Bedrock AI label and summary generation
MATH_UPDATER_AWS_AI_LABEL_SUMMARY_ENABLE=false
MATH_UPDATER_AWS_AI_LABEL_SUMMARY_REGION=us-east-1
MATH_UPDATER_AWS_AI_LABEL_SUMMARY_MODEL_ID=mistral.mistral-large-3-675b-instruct
MATH_UPDATER_AWS_AI_LABEL_SUMMARY_TEMPERATURE=0.15
MATH_UPDATER_AWS_AI_LABEL_SUMMARY_TOP_P=0.9
MATH_UPDATER_AWS_AI_LABEL_SUMMARY_MAX_TOKENS=8192
MATH_UPDATER_AWS_CLIENT_CONNECT_TIMEOUT_SECONDS=2.0
MATH_UPDATER_AWS_AI_LABEL_SUMMARY_READ_TIMEOUT_SECONDS=12.0
MATH_UPDATER_AWS_DESCRIPTION_TRANSLATION_READ_TIMEOUT_SECONDS=12.0
MATH_UPDATER_AWS_SECRET_READ_TIMEOUT_SECONDS=5.0

# Dev-only simulation providers for load-testing retry/fallback logic without
# Bedrock or Google calls. Validation refuses to start if these are enabled
# without AGORA_DEV_MODE=true.
MATH_UPDATER_SIMULATION_PROVIDERS_ENABLE=false
# One of: off, success, retryable_error, retryable_error_then_success, non_retryable_error
MATH_UPDATER_AI_DESCRIPTION_SIMULATION_MODE=off
MATH_UPDATER_DESCRIPTION_TRANSLATION_SIMULATION_MODE=off
MATH_UPDATER_SIMULATION_RETRYABLE_FAILURE_ATTEMPTS=1

# Custom AI prompt (optional - defaults to built-in prompt if unspecified)
# MATH_UPDATER_AWS_AI_LABEL_SUMMARY_PROMPT="Your custom prompt here..."

# AWS Secrets Manager region for optional secret-backed credentials
# MATH_UPDATER_AWS_SECRET_REGION=us-east-1

# Google Cloud Translation API Configuration
# Requires MATH_UPDATER_AWS_AI_LABEL_SUMMARY_ENABLE=true.
# Optional: Translation API location (default: "us-central1")
# MATH_UPDATER_GOOGLE_CLOUD_TRANSLATION_LOCATION=us-central1

# Optional: API endpoint (default: "translate.googleapis.com")
# MATH_UPDATER_GOOGLE_CLOUD_TRANSLATION_ENDPOINT=translate.googleapis.com

# Optional: Translation API request timeout in seconds (default: 10.0)
# MATH_UPDATER_GOOGLE_CLOUD_TRANSLATION_TIMEOUT_SECONDS=10.0

# Authentication Options (choose one):

# Option 1: GOOGLE_APPLICATION_CREDENTIALS (local development)
# Point to the path of your service account JSON key file
# The project_id will be extracted from this file automatically
# MATH_UPDATER_GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Option 2: AWS Secrets Manager (production - recommended)
# Store the entire Google Cloud service account JSON in AWS Secrets Manager
# The project_id will be extracted from the service account JSON automatically
# If set, this takes precedence over GOOGLE_APPLICATION_CREDENTIALS
# In production, this should be defined and point to the secret containing the service account JSON
# MATH_UPDATER_GOOGLE_CLOUD_SERVICE_ACCOUNT_AWS_SECRET_KEY=google-cloud-service-account
