{
    "include": ["src/**/*"],
    "exclude": [
        "**/*.test.ts",
        "**/*.spec.ts",
        "node_modules",
        "**/node_modules/*"
    ],
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2023"],
        "module": "node16",
        "moduleResolution": "Node16",
        "rootDir": "src",
        "paths": {
            "@/*": ["./src/*"]
        },
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "outDir": "dist",
        "declaration": true,
        "sourceMap": true
    }
}
