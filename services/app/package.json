{
  "name": "app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/lucide": "^1.2.106",
    "@iconify-json/simple-icons": "^1.2.81",
    "@iconify/tailwind4": "^1.2.3",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-netlify": "^6.0.4",
    "@sveltejs/enhanced-img": "^0.10.4",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.6.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "svelte-eslint-parser": "^1.6.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@fontsource-variable/albert-sans": "^5.2.8",
    "@inlang/paraglide-js": "^2.18.0",
    "@justinribeiro/lite-youtube": "^1.9.0",
    "@sentry/sveltekit": "^10.52.0",
    "bits-ui": "^2.18.1",
    "gray-matter": "^4.0.3",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "eslint>ajv": "^6.14.0",
      "@eslint/eslintrc>ajv": "^6.14.0",
      "cookie": ">=0.7.0"
    }
  }
}
