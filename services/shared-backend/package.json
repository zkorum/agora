{
    "name": "@zkorum/agora-shared-backend",
    "version": "1.0.0",
    "type": "module",
    "description": "Shared backend code for API and worker services",
    "main": "index.js",
    "scripts": {
        "sync": "bash scripts/rsync_and_sed.sh",
        "test": "vitest run",
        "format:write": "prettier --write \"**/*.{js,ts,jsx,tsx,vue,scss,html,md,json}\"",
        "format:check": "prettier . --check"
    },
    "keywords": [
        "shared",
        "backend"
    ],
    "author": "ZKorum SAS <hello@zkorum.com>",
    "license": "AGPL-3.0",
    "dependencies": {
        "@aws-sdk/client-secrets-manager": "^3.1037.0",
        "@aws-sdk/client-translate": "^3.1037.0",
        "@google-cloud/translate": "^9.3.0",
        "@valkey/valkey-glide": "^2.3.1",
        "drizzle-orm": "^0.45.2",
        "fastify": "^5.8.5",
        "p-limit": "^7.3.0",
        "postgres": "^3.4.9",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "pino": "^10.3.1",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vitest": "^4.1.5"
    },
    "pnpm": {
        "overrides": {
            "fast-xml-parser": ">=5.3.6",
            "brace-expansion": "2.0.3",
            "minimatch": "9.0.7",
            "@tootallnate/once": "3.0.1"
        }
    }
