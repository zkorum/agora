{
    "name": "@zkorum/agora-load-testing",
    "version": "1.0.0",
    "description": "k6 load testing suite for Agora voting system",
    "type": "module",
    "scripts": {
        "build": "vite build",
        "test:single-conversation": "k6 run dist/scenario1-single-conversation.cjs",
        "test:multiple-conversations": "k6 run dist/scenario2-multiple-conversations.cjs",
        "test:all": "pnpm run build && pnpm run test:single-conversation && pnpm run test:multiple-conversations",
        "lint": "eslint .",
        "format:write": "prettier --write \"**/*.{js,ts,jsx,tsx,vue,scss,html,md,json}\"",
        "format:check": "prettier . --check"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/k6": "^1.7.0",
        "@types/node": "^25.6.2",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2",
        "vite": "^8.0.11"
    },
    "dependencies": {
        "@ucans/ucans": "^0.12.0",
        "@zkorum/keystore-idb": "^0.18.1",
        "fast-text-encoding": "^1.0.6",
        "tweetnacl": "^1.0.3",
        "uint8arrays": "^5.1.0"
    },
    "pnpm": {
        "overrides": {
            "eslint>ajv": "^6.14.0",
            "@eslint/eslintrc>ajv": "^6.14.0",
            "@stablelib/ed25519": "2.1.0",
            "js-yaml": ">=4.1.1"
        }
    }
}
