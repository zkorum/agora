{
    "name": "@zkorum/agora-load-testing",
    "version": "1.0.0",
    "description": "k6 load testing suite for Agora voting system",
    "type": "module",
    "scripts": {
        "build": "vite build",
        "test:conversation-voting": "node ../../scripts/dev-log-runner.mjs --service load-testing -- bash -lc 'cd services/load-testing && k6 run --summary-export \"$AGORA_LOG_SUMMARY_FILE\" dist/scenario1-single-conversation.cjs'",
        "test:all": "pnpm run build && pnpm run test:conversation-voting",
        "lint": "eslint .",
        "format:write": "prettier --write \"**/*.{js,ts,jsx,tsx,vue,scss,html,md,json}\"",
        "format:check": "prettier . --check"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/k6": "^1.7.0",
        "@types/node": "^26.1.1",
        "@types/sanitize-html": "^2.16.1",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0",
        "vite": "^8.0.5"
    },
    "dependencies": {
        "@ucans/ucans": "^0.12.0",
        "@zkorum/keystore-idb": "^0.18.1",
        "fast-text-encoding": "^1.0.6",
        "html-entities": "^2.6.0",
        "sanitize-html": "^2.17.5",
        "tweetnacl": "^1.0.3",
        "uint8arrays": "^5.1.0"
    },
    "pnpm": {
        "overrides": {
            "eslint>ajv": "^6.14.0",
            "@eslint/eslintrc>ajv": "^6.14.0",
            "@stablelib/ed25519": "2.1.0",
            "js-yaml": ">=4.1.1"
        }
    }
}
